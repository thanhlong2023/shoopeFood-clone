<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orders</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="container">
      <div class="card">
        <h1>Orders</h1>
        <ul>
          <% orders.forEach((order) => { %>
            <li>#<%= order.id %> - <%= order.customer %> - <%= order.status %></li>
          <% }) %>
        </ul>
      </div>
    </div>
  </body>
</html>