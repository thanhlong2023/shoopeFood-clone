<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground Service: bắt buộc để chạy tracking nền liên tục -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- API 34 (Android 14+): khai báo loại foreground service cụ thể -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- API 33 (Android 13+): hiển thị notification cho service -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />


    <application
        android:name=".ShoopeFoodApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_app_logo"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShoopeFood"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.HomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.MerchantHomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.MerchantQuickInventoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.MerchantHomeActivity" />

        <activity
            android:name=".ui.MerchantRestaurantProfileActivity"
            android:exported="false"
            android:parentActivityName=".ui.MerchantHomeActivity" />

        <activity
            android:name=".ui.DriverHomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.RestaurantDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.HomeActivity" />

        <activity
            android:name=".ui.CartActivity"
            android:exported="false"
            android:parentActivityName=".ui.HomeActivity" />

        <activity
            android:name=".ui.OrdersActivity"
            android:exported="false"
            android:parentActivityName=".ui.HomeActivity" />

        <activity
            android:name=".ui.OrderDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.HomeActivity" />

        <!--
            LocationTrackingService: Foreground Service đảm bảo GPS tracking
            liên tục ngay cả khi app bị minimize hoặc màn hình bị khóa.
            foregroundServiceType="location" bắt buộc trên Android 14+ (API 34).
        -->
        <service
            android:name=".location.LocationTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>
</manifest>
