<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_app_logo"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShoopeFood"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.HomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.RestaurantDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.HomeActivity" />

        <activity
            android:name=".ui.CartActivity"
            android:exported="false"
            android:parentActivityName=".ui.HomeActivity" />

        <activity
            android:name=".ui.OrdersActivity"
            android:exported="false"
            android:parentActivityName=".ui.HomeActivity" />

        <activity
            android:name=".ui.OrderDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.OrdersActivity" />

    </application>
</manifest>
