<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ShoopeFood" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryVariant">@color/brand_green_dark</item>
        <item name="colorSecondary">@color/brand_orange</item>
        <item name="android:statusBarColor">@color/brand_green_dark</item>
        <item name="android:windowBackground">@color/surface_bg</item>
    </style>

    <style name="CustomerCategoryChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_customer_category_chip</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="RestaurantCardImageShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
