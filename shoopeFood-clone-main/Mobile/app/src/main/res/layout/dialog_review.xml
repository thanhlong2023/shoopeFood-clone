<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvDriverReviewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đánh giá Tài xế"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <RatingBar
        android:id="@+id/rbDriverRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:numStars="5"
        android:rating="5"
        android:stepSize="1"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etDriverComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/edit_text"
        android:hint="Nhận xét về tài xế (không bắt buộc)"
        android:inputType="textMultiLine"
        android:lines="2"
        android:padding="8dp"
        android:textSize="14sp"
        android:visibility="gone" />

    <View
        android:id="@+id/vDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#DDDDDD"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvRestaurantReviewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đánh giá Nhà hàng"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <RatingBar
        android:id="@+id/rbRestaurantRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:numStars="5"
        android:rating="5"
        android:stepSize="1"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etRestaurantComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/edit_text"
        android:hint="Nhận xét về món ăn (không bắt buộc)"
        android:inputType="textMultiLine"
        android:lines="2"
        android:padding="8dp"
        android:textSize="14sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnSubmitReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="#FFC107"
        android:text="Gửi đánh giá"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>
